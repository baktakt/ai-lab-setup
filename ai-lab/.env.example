# Cloud LLM API keys (optional — local models work without these)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Hermes dashboard basic auth
HERMES_DASHBOARD_BASIC_AUTH_USERNAME=admin
HERMES_DASHBOARD_BASIC_AUTH_PASSWORD=change-this

# Hermes user-facing workspace mounted inside the container as /workspace
HERMES_WORKSPACE_DIR=~/workspace

# Optional future integrations
# GOOGLE_API_KEY=
# GITHUB_TOKEN=
# NOTION_API_KEY=
# SLACK_BOT_TOKEN=

# Optional Home Assistant profile
ENABLE_HOME_ASSISTANT=false
CONBEE_DEVICE=/dev/ttyACM0
CONBEE_CONTAINER_DEVICE=/dev/ttyACM0
TZ=UTC
