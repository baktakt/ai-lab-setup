# Cloud LLM API keys (optional — local models work without these)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional future integrations
# GOOGLE_API_KEY=
# GITHUB_TOKEN=
# NOTION_API_KEY=
# SLACK_BOT_TOKEN=

# Optional Home Assistant profile
ENABLE_HOME_ASSISTANT=false
CONBEE_DEVICE=/dev/ttyACM0
CONBEE_CONTAINER_DEVICE=/dev/ttyACM0
TZ=UTC
